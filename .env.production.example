# =============================================================================
# LixyLearning - Plantilla de variables de entorno (producción / EC2)
# =============================================================================
# Copia a .env y reemplaza los valores. No subas .env con secretos a Git.
# Las variables NEXT_PUBLIC_* se fijan en el BUILD del frontend: tras cambiarlas,
# reconstruye: docker compose up -d --build
# =============================================================================

# --- Frontend (Next.js) - URLs públicas ---
NEXT_PUBLIC_BACKEND_URL=https://tu-dominio.example.com
NEXT_PUBLIC_FRONTEND_URL=https://tu-dominio.example.com

# Opcional (reservada; la UI de contacto puede no mostrarla).
# NEXT_PUBLIC_CONTACT_EMAIL=contacto@tu-dominio.org

# --- Formulario de contacto (API Resend; sin SMTP) ---
# https://resend.com/docs/send-with-python
# RESEND_API_KEY=re_xxxxxxxx
# RESEND_FROM_EMAIL=Tu App <notificaciones@tu-dominio-verificado.com>
# CONTACT_TO_EMAIL=donde_recibes@ejemplo.com

# --- Base de datos PostgreSQL ---
# En Docker Compose el host es el nombre del servicio: postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=tu_password_seguro
POSTGRES_DB=lixylearning_db
DATABASE_URL=postgresql://postgres:tu_password_seguro@postgres:5432/lixylearning_db

# --- Autenticación (JWT tradicional) ---
# Genera uno con: openssl rand -base64 32
JWT_SECRET=tu_jwt_secret_muy_largo_y_aleatorio

# --- Panel de administración (/api/admin/* y ruta /admin del frontend) ---
# Lista separada por comas: correos en minúsculas se comparan sin distinguir mayúsculas.
# ADMIN_EMAILS=admin@tu-dominio.example.com,otro@ejemplo.com
# O IDs numéricos de users.user_id:
# ADMIN_USER_IDS=1

# --- AWS Cognito (login/registro + OAuth Google/Microsoft) ---
# Mismos valores en backend (sin NEXT_PUBLIC_) y en frontend (NEXT_PUBLIC_*).
# Ver docs/COGNITO_SETUP.md
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx

# Intercambio OAuth (Hosted UI + PKCE): mismo prefijo que el dominio de Cognito
# (solo el prefijo, sin https:// ni .auth.region...)
COGNITO_DOMAIN=tu_prefijo_dominio_cognito
# Debe coincidir exactamente con "Allowed callback URLs" del app client en Cognito
COGNITO_OAUTH_REDIRECT_URI=https://tu-dominio.example.com/auth/callback

NEXT_PUBLIC_USE_COGNITO=true
NEXT_PUBLIC_COGNITO_REGION=us-east-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_COGNITO_DOMAIN=tu_prefijo_dominio_cognito
NEXT_PUBLIC_COGNITO_OAUTH_REDIRECT_URI=https://tu-dominio.example.com/auth/callback

# Opcional: si en Cognito el nombre del proveedor no es exactamente Google / Microsoft
# NEXT_PUBLIC_COGNITO_IDP_GOOGLE=Google
# NEXT_PUBLIC_COGNITO_IDP_MICROSOFT=Microsoft

# --- APIs de Inteligencia Artificial ---
GEMINI_API_KEY=tu_gemini_api_key
OPENAI_API_KEY=tu_openai_api_key

# --- Google Cloud (Text-to-Speech, etc.) ---
GOOGLE_API_KEY=tu_google_api_key

# --- Pixabay (imágenes para flashcards) ---
# https://pixabay.com/api/docs/
PIXABAY_API_KEY=tu_pixabay_api_key
